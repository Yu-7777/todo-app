<!DOCTYPE html>
<html>
<head>
  <title>Todo App</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    h1 { color: #333; }
    .task { 
      border: 1px solid #ddd; 
      padding: 10px; 
      margin: 10px 0; 
      border-radius: 5px; 
    }
    .completed { 
      background-color: #f0f8f0; 
      text-decoration: line-through; 
    }
    .new-task { 
      background-color: #f9f9f9; 
      padding: 15px; 
      margin: 20px 0; 
      border-radius: 5px; 
    }
    input, textarea { 
      width: 100%; 
      padding: 5px; 
      margin: 5px 0; 
    }
    button { 
      background-color: #007bff; 
      color: white; 
      padding: 8px 16px; 
      border: none; 
      border-radius: 3px; 
      cursor: pointer; 
    }
    button:hover { background-color: #0056b3; }
    .btn-edit { background-color: #28a745; }
    .btn-delete { background-color: #dc3545; }
    a { text-decoration: none; color: white; }
  </style>
</head>
<body>
  <h1>📝 Todo App - タスク一覧</h1>
  
  <!-- 新規タスク作成フォーム -->
  <div class="new-task">
    <h3>新しいタスクを追加</h3>
    <%= form_with model: Task.new, local: true do |form| %>
      <p>
        <%= form.label :title, "タスク名:" %>
        <%= form.text_field :title, placeholder: "例: 買い物に行く" %>
      </p>
      
      <p>
        <%= form.label :description, "詳細:" %>
        <%= form.text_area :description, placeholder: "詳細を入力してください", rows: 3 %>
      </p>
      
      <p>
        <%= form.submit "タスクを追加", class: "button" %>
      </p>
    <% end %>
  </div>

  <!-- タスク統計 -->
  <div style="background-color: #e9ecef; padding: 10px; border-radius: 5px; margin: 20px 0;">
    <strong>統計:</strong>
    全タスク: <%= @tasks.count %>個 | 
    完了: <%= @completed_tasks.count %>個 | 
    未完了: <%= @not_completed_tasks.count %>個
  </div>

  <!-- タスク一覧 -->
  <h2>タスク一覧</h2>
  
  <% if @tasks.any? %>
    <% @tasks.each do |task| %>
      <div class="task <%= 'completed' if task.completed %>">
        <h3>
          <%= task.completed ? "✅" : "⏰" %>
          <%= task.title %>
        </h3>
        
        <% if task.description.present? %>
          <p><strong>詳細:</strong> <%= task.description %></p>
        <% end %>
        
        <p>
          <small>
            作成日: <%= task.created_at.strftime("%Y年%m月%d日 %H:%M") %>
            <% if task.completed %>
              | 完了日: <%= task.updated_at.strftime("%Y年%m月%d日 %H:%M") %>
            <% end %>
          </small>
        </p>
        
        <div>
          <!-- 完了/未完了の切り替え -->
          <%= form_with model: task, local: true, method: :patch do |form| %>
            <%= form.hidden_field :completed, value: !task.completed %>
            <%= form.submit task.completed ? "未完了にする" : "完了にする", 
                style: "background-color: #{task.completed ? '#ffc107' : '#28a745'};" %>
          <% end %>
          
          <!-- 詳細表示 -->
          <button style="background-color: #17a2b8;">
            <%= link_to "詳細", task_path(task) %>
          </button>
          
          <!-- 編集 -->
          <button class="btn-edit">
            <%= link_to "編集", edit_task_path(task) %>
          </button>
          
          <!-- 削除 -->
          <button class="btn-delete">
            <%= link_to "削除", task_path(task), method: :delete, 
                data: { confirm: "本当に削除しますか？" } %>
          </button>
        </div>
      </div>
    <% end %>
  <% else %>
    <div style="text-align: center; padding: 50px; color: #666;">
      <h3>📝 まだタスクがありません</h3>
      <p>上のフォームから最初のタスクを追加してみましょう！</p>
    </div>
  <% end %>
  
  <hr style="margin: 30px 0;">
  <p style="text-align: center; color: #666;">
    <small>Todo App - 簡単なタスク管理アプリ</small>
  </p>
</body>
</html>